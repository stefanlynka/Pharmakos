  m_Name: Narcissus
  m_EditorClassIdentifier: 
  EventText: "A beautiful man ignores your approach in favour of looking at his beautiful
    reflection. A closer look reveals he\u2019s fairly gaunt; it appears he\u2019s
    been staring at his reflection for some time now. Beyond the man\u2019s self
    obsession, there is genuine love in his eyes. You try to direct the same look
    of love at something."
  BackgroundImage: {fileID: 21300000, guid: ea90e11e6144d00418944968662f54b8, type: 3}
  ImageStartingPosition: {x: 20.5, y: -48}
  ImageStartingScale: {x: 18, y: 18, z: 1}
  SummaryPosition: 1
  Options:
  - OptionText: You turn your eye to those that follow you\n(Copy Card in deck)
    Outcome:
      OutcomeType: 6
      RewardInfo: []
  - OptionText: You turn your eye to your own reflection\n(Gain Card)
    Outcome:
      OutcomeType: 1
      RewardInfo:
      - Reflection
