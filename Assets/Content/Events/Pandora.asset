  m_Script: {fileID: 11500000, guid: c4e8a1f9d0b24e5a8c3f2d1b0e9a7c6d, type: 3}
  m_Name: Pandora
  m_EditorClassIdentifier: 
  EventText: "A woman sits hunched over a box covered in swirling patterns. As you
    approach her, she doesn\u2019t meet your gaze, only muttering that she couldn\u2019t
    have known. She tilts the box from side to side and whispers that there\u2019s
    still something within, but she doesn\u2019t have the heart to open it."
  BackgroundImage: {fileID: 21300000, guid: 745fd54197b168c469231ed5df16fe4d, type: 3}
  ImageStartingPosition: {x: -5, y: -55}
  ImageStartingScale: {x: 18, y: 18, z: 1}
  SummaryPosition: 2
  Options:
  - OptionText: Offer to take the box from her\n(Gain Trinket)
    Outcome:
      OutcomeType: 2
      RewardInfo:
      - PandorasBox
  - OptionText: Offer to open the box for her\n(Gain Trinket)
    Outcome:
      OutcomeType: 2
      RewardInfo:
      - PandorasHope
