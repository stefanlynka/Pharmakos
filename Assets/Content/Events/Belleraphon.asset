  m_Script: {fileID: 11500000, guid: c4e8a1f9d0b24e5a8c3f2d1b0e9a7c6d, type: 3}
  m_Name: Belleraphon
  m_EditorClassIdentifier: 
  EventText: "Puzzled by the sound of whinnying above you, you look up to see a figure
    riding a winged horse. With a wave and a wide grin he descends and lands beside
    you. He is eager to hear of your tales and share his own. He explains that his
    greatest desire is to see the Gods themselves and that with Pegasus he\u2019ll
    now be able to fly to Mt Olympus directly. He seems unperturbed by the knowledge
    that seeing the Gods in their true form comes with a terrible price.\r\n\u201CI
    have flown across the mortal world and seen all it has to offer. What life would
    it be if I didn\u2019t seek what\u2019s higher?\u201D\r"
  BackgroundImage: {fileID: 21300000, guid: e2af01bc5ed0c1d49b36cd4a3f69f911, type: 3}
  ImageStartingPosition: {x: 28, y: -42}
  ImageStartingScale: {x: 18, y: 18, z: 1}
  SummaryPosition: 2
  Options:
  - OptionText: Invite him to join you as you too seek a God\n(Gain Card)
    Outcome:
      OutcomeType: 1
      RewardInfo:
      - Pegasus
  - OptionText: Hear more of his tales before wishing him luck\n(Gain Rituals)
    Outcome:
      OutcomeType: 3
      RewardInfo:
      - AphroditeMajor
      - PoseidonMajor
