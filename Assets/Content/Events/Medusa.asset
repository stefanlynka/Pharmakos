  ImageStartingScale: {x: 18, y: 18, z: 1}
  SummaryPosition: 1
  Options:
  - OptionText: He accepted his fate and wished to see what few others had\n(Gain
      Heartstring)
    Outcome:
      OutcomeType: 8
      RewardInfo: []
  - OptionText: His resolve failed him. Not all are ready for such a quest\n(Remove
      Card from deck)
