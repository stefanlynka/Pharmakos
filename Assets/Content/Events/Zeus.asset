  m_Script: {fileID: 11500000, guid: c4e8a1f9d0b24e5a8c3f2d1b0e9a7c6d, type: 3}
  m_Name: Zeus
  m_EditorClassIdentifier: 
  EventText: "You overhear a hushed discussion between locals troubled by recent
    events. One of them recounts seeing an immense eagle appear from the clouds,
    its eyes impossible to make out. It descended upon a woman in the field below,
    carrying her away back into the clouds. It must have been deaf to ignore the
    woman\u2019s cries. It must have been blind for they couldn\u2019t see its eyes.
    They wondered at the nature of such a beast and what form of enjoyment it could
    take from a prey it neither sees nor hears."
  BackgroundImage: {fileID: 21300000, guid: 0856db2dc1261f741b7d85797a9ec8a0, type: 3}
  ImageStartingPosition: {x: 33, y: -66}
  ImageStartingScale: {x: 20, y: 20, z: 1}
  SummaryPosition: 2
  Options:
  - OptionText: You know better than to clash with Zeus\n(Gain Rituals)
    Outcome:
      OutcomeType: 3
      RewardInfo:
      - ZeusMinor
      - ZeusMajor
  - OptionText: This cannot stand\n(Rebuke the Gods)
    Outcome:
      OutcomeType: 11
      RewardInfo: []
