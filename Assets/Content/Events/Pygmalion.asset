  m_Script: {fileID: 11500000, guid: c4e8a1f9d0b24e5a8c3f2d1b0e9a7c6d, type: 3}
  m_Name: Pygmalion
  m_EditorClassIdentifier: 
  EventText: "The sculptor leans back in his chair, his half-finished work far from
    his mind. You follow his sight to a particular statue that stands nearby. Only
    when the statue returns his gaze with a raised eyebrow and a suppressed grin
    do you realize she\u2019s alive. While her pale skin and still demeanor make
    her blend in among the statues in the workshop, the vibrance in the look they
    share is palpable.\n\u201CI will not take all the credit for making her,\u201D
    the sculptor says to you without turning his gaze. \u201CShe is the sum of all
    the beauty I have seen. The Gods did the rest.\u201D"
  BackgroundImage: {fileID: 21300000, guid: 999b7a017a77f554b9013eb5251dd4b3, type: 3}
  ImageStartingPosition: {x: 60, y: -42}
  ImageStartingScale: {x: 20, y: 20, z: 1}
  SummaryPosition: 2
  Options:
  - OptionText: Remember who all the sacrifice is for\n(Gain Heartstring)
    Outcome:
      OutcomeType: 8
      RewardInfo: []
  - OptionText: "Reflect on the beauty you\u2019ve encountered\\n(Become enemy from
      previous combat)"
    Outcome:
      OutcomeType: 9
      RewardInfo: []
